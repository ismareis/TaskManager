{
  "name": "src",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:unit": "cross-env NODE_ENV=test jest --testPathIgnorePatterns=tests/infra/http --runInBand",
    "test:integration": "cross-env NODE_ENV=test jest tests/infra/http --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "start": "node src/server.js",
    "migrate": "knex migrate:latest --knexfile src/infra/database/knex/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile src/infra/database/knex/knexfile.js",
    "seed": "knex seed:run --knexfile src/infra/database/knex/knexfile.js",
    "reset-db": "knex migrate:rollback --all --knexfile src/infra/database/knex/knexfile.js && knex migrate:latest --knexfile src/infra/database/knex/knexfile.js && knex seed:run --knexfile src/infra/database/knex/knexfile.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^173.0.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/infra/database/knex/**",
      "!src/infra/database/migrations/**",
      "!src/infra/database/seeds/**"
    ],
    "coverageReporters": ["text", "lcov"]
  }
}
